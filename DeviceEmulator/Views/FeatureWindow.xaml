<Window x:Class="DeviceEmulator.Views.FeatureWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DeviceEmulator.Views"
        mc:Ignorable="d"
        Title="Device Feature Set" Height="300" Width="370" Background="White">
    <Grid x:Name="GrdFeature">
        <StackPanel HorizontalAlignment="Left" Height="252" Margin="10,10,0,0" VerticalAlignment="Top" Width="345">
            <Label Content="En/Disabled Features:" FontFamily="Segoe UI Black" FontSize="14"/>
            <ListBox x:Name="ListBoxFeatures" Height="180" Margin="10,10,10,10" ItemsSource="{Binding DeviceFeatures}" ScrollViewer.VerticalScrollBarVisibility="Visible">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid x:Name="FeatureGrd">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="35" />
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" HorizontalAlignment="Left" Content="{Binding FeatureId}" />
                            <Label Grid.Column="1" HorizontalAlignment="Left" Content="{Binding FeatureName}" />
                            <Label Grid.Column="2" HorizontalAlignment="Center" Content="{Binding IsEnabled}" />
                            <Label Grid.Column="3" HorizontalAlignment="Left" Content="{Binding LastModified}" />
                            <Label Grid.Column="4" HorizontalAlignment="Left" Content="{Binding CreditCount}" />
                            <Button Grid.Column="5" HorizontalAlignment="Center" Width="25" Height="20" Content="Use" IsEnabled="{Binding IsEnabled}" Click="ButtonFeatureUseClick"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <Button Width="80" Height="20" Content="OK" IsDefault="True" Click="ButtonOkClick"/>
        </StackPanel>
    </Grid>
</Window>
