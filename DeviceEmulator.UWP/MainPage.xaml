<Page
    x:Class="DeviceEmulator.UWP.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" Width="560" Height="440">

    <Grid x:Name="GrdMain" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions >
            <RowDefinition Height="70"/>
            <RowDefinition Height="40" />
            <RowDefinition Height="50"/>
            <RowDefinition Height="35"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="20" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="2*" />
        </Grid.ColumnDefinitions>

        <!--Header-->
        <Grid Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="40" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Column="0" Grid.Row="0" Margin="5" FontFamily="Segoe UI Black" FontSize="24">
                IoT Hub Device Emulator
            </TextBlock>

            <TextBlock Grid.Column="0" Grid.Row="1" FontFamily="Segoe UI Black" FontSize="12" Margin="5,0.5,0.5,0">
                Microsoft Azure Communication
            </TextBlock>

            <Border Grid.Row="0" Grid.Column="1" Grid.RowSpan="2" Background="White">
                <Image  HorizontalAlignment="Right" Margin="0,5,0,15" Source="/Assets/Microsoft-logo_rgb_c-gray.png" />
            </Border>
        </Grid>
        <!--Header-->

        <!--Ingestion Data-->
        <!-- Machine Selection -->
        <ComboBox Grid.Column="0" Grid.Row="1" Margin="5" Width="175" ItemsSource="{Binding Configuration.DeviceConfiguration}" DisplayMemberPath="DeviceId" SelectedIndex="{Binding IndexSelectedMachine, Mode=TwoWay}" SelectionChanged="SelectedMachine_OnSelectionChanged"/>
        <StackPanel Grid.Column="1" Grid.Row="1" Orientation="Horizontal">
            <TextBlock Text="Device Id" Margin="0,10"/>
            <TextBlock Name="EnvironmentLbl" Text="Dev" Margin="200,0,5,0" FontWeight="Bold" Foreground="Blue"/>
            <TextBlock Name="EmuDeviceLbl" Text="(Desktop)" FontWeight="Bold" Foreground="Blue"/>
        </StackPanel>

        <!--Case Emulation - File based Ingest-->
        <ComboBox Grid.Column="0" Grid.Row="2" Margin="5" Width="175" ItemsSource="{Binding TelemetryIngestFiles}" DisplayMemberPath="FileName" SelectedIndex="{Binding IndexSelectedTelemetryIngestFile, Mode=TwoWay}"/>
        <StackPanel  Grid.Column="1" Grid.Row="2" Orientation="Horizontal">
            <TextBlock Text="Message Type" Margin="0,10"/>
            <Button Name="IngestBtn" Content="Ingest" Margin="5" Width="65" Click="IngestTelemetry_Click"/>
            <Button Name="ShowFeaturesBtn" Content="Show Features" Margin="5" Width="120" Click="ShowFeature_Click" IsEnabled="False"/>
        </StackPanel>

        <StackPanel Grid.Column="0" Grid.Row="3" Grid.ColumnSpan="2" Orientation="Horizontal">
            <RadioButton Content="100" GroupName="Alerts" Tag="1" Margin="2" Checked="StatusChanges_Checked" />
            <RadioButton Content="200" GroupName="ALerts" Tag="2" Margin="2" Checked="StatusChanges_Checked" />
            <RadioButton Content="300" GroupName="Alerts" Tag="3" Margin="2" Checked="StatusChanges_Checked" />
            <RadioButton Content="400" GroupName="Alerts" Tag="4" Margin="2" Checked="StatusChanges_Checked" />
            <RadioButton Content="500" GroupName="Alerts" Tag="5" Margin="2" Checked="StatusChanges_Checked" />
        </StackPanel>
        <!--Ingestion Data-->

        <Image Grid.Row="4" Grid.Column="0" Margin="0" HorizontalAlignment="Center" VerticalAlignment="Center" Source="/Assets/Azure-IoT-Hub-Shape.png" />
        <Grid Grid.Row="4" Grid.Column="1" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="25" />
                <RowDefinition Height="75" />
                <RowDefinition Height="25" />
                <RowDefinition Height="50" />
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Status" Margin="5,0"/>
            <TextBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="5" BorderBrush="Black" Text="{Binding DisplayStatus}" TextWrapping="Wrap" ></TextBox>
            <TextBlock Grid.Row="2" Grid.Column="0" Text="Arrived Command" Margin="5,0"/>
            <TextBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Margin="5" BorderBrush="Black" Text="{Binding ArrivedCommandsStatus}" ></TextBox>
            <Button Grid.Row="4" Grid.Column="0" Content="Clear" Click="ClearStatus_Click" Margin="5" Width="70" HorizontalAlignment="Center" />
            <Button Name="ReceiceCommandsBtn" Grid.Row="4" Grid.Column="1" Content="Start Receiving" Click="ReceiveCommands_Click" Margin="5" Width="120" HorizontalAlignment="Center"/>
        </Grid>

        <Border Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Background="White">
        </Border>

    </Grid>
</Page>
